# ─────────────────────────────────────────────────────────────────────────────
# TripleEdge Alpaca Paper-Trading Bot — environment template
#
# 1. Copy this file to `.env` in the repo root:    cp .env.example .env
# 2. Fill in your PAPER trading keys (from https://app.alpaca.markets).
# 3. Confirm .env is gitignored:                    git check-ignore .env
# 4. Run the bot in alert_only first:               python -m bot.run
#
# NEVER commit the real .env. It contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Alpaca PAPER trading keys (REQUIRED).
# Get them at app.alpaca.markets → Paper Trading → API Keys.
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Bot mode (default: alert_only — no orders ever sent)
# Allowed: alert_only | dry_run | execute
BOT_MODE=alert_only

# ── DANGEROUS: live trading — leave commented out unless you know what you're doing
# To enable real-money trading you must set BOTH variables to true.
# The bot will print a 5-second countdown warning at startup if these are set.
# LIVE_TRADING=true
# LIVE_TRADING_CONFIRMED=true

# Tiingo fallback for long-history weekly bars (recommended — Alpaca free IEX
# feed often doesn't return 100+ weeks needed for the UGL regime SMA).
TIINGO_API_KEY=your_tiingo_api_key_here

# Optional Telegram notification of each bot run
# Reuses your existing TELEGRAM_BOT_TOKEN if you already have one set up.
# TELEGRAM_BOT_TOKEN=
# BOT_NOTIFY_CHAT_ID=
